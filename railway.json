{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS_NODE_BUILDER",
    "nodeVersion": "20"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartDelay": 10
  }
}
