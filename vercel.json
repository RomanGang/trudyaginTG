{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.+\\.(js|css|png|jpg|jpeg|svg|ico)$)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.+)",
      "dest": "/frontend/index.html"
    }
  ]
}
